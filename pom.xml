		<!--
		HACK: Fork the compiler into a separate javac process to avoid
		a javac bug ("endPosTable already set") that otherwise triggers
		when the JMH annotation processor generates sources in-process.
		-->
		<maven.compiler.fork>true</maven.compiler.fork>
	</properties>

	<dependencies>
		<!-- Test scope dependencies -->
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-api</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.junit.jupiter</groupId>
